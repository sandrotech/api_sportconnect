generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums Globais ───────────────────────────────────────────────────────────

enum Role {
  ARENA
  ATLETA
  PROFISSIONAL
}

enum ArenaStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Enums de Grupo ──────────────────────────────────────────────────────────

enum GroupVisibility {
  PUBLIC       // Qualquer atleta pode entrar direto
  PRIVATE      // Somente por link de convite
  REQUEST_ONLY // Solicita entrada, admin aprova
}

enum GroupMemberRole {
  OWNER     // Dono do grupo — permissões totais
  CO_OWNER  // Co-dono — tudo exceto deletar grupo
  MEMBER    // Membro aprovado
  GUEST     // Convidado aguardando aprovação
}

enum GroupMemberStatus {
  PENDING  // Aguardando aprovação
  APPROVED // Membro ativo
  REJECTED // Solicitação negada
  INVITED  // Convidado por link (aguardando aceite)
  BANNED   // Banido do grupo
}

// ─── Enums de Sessão de Jogo ─────────────────────────────────────────────────

enum GameSessionStatus {
  DRAFT        // Rascunho (configurando)
  OPEN         // Aberta para inscrição
  CONFIRMED    // Confirmada
  IN_PROGRESS  // Acontecendo agora
  FINISHED     // Finalizada, avaliações liberadas
  CANCELLED    // Cancelada
}

enum GamePlayerStatus {
  STARTER   // Titular
  RESERVE   // Reserva
  CONFIRMED // Confirmou presença no dia
  ABSENT    // Não foi
  PROMOTED  // Reserva promovido a titular
}

enum GameVisibility {
  GROUP_ONLY // Somente membros do grupo
  PUBLIC     // Aberta para qualquer atleta da plataforma
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  password     String
  role         Role
  createdAt    DateTime  @default(now())
  avatar       String?
  banner       String?
  cpf          String?   @unique
  dataNascimento DateTime?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  walletBalance        Int       @default(0)

  arena        Arena?
  atleta       Atleta?
  profissional Profissional?
  groups       GroupMember[]
  gamePlayers            GamePlayer[]
  ratingsGiven           GameRating[]         @relation("RatingGiven")
  ratingsReceived        GameRating[]         @relation("RatingReceived")
  gameSessionsCreated    GameSession[]        @relation("GameSessionCreator")
  walletTransactions     WalletTransaction[]
  reservas               Reserva[]            @relation("ReservasAtleta")
}

model Arena {
  id          Int         @id @default(autoincrement())
  userId      Int         @unique
  nomeArena   String
  cnpj        String
  razaoSocial String @default("")
  bairro      String @default("")
  cidade      String @default("")
  estado      String @default("")
  endereco    String @default("")
  cep         String @default("")
  numero      String @default("")
  telefone       String @default("")
  horaAbertura   String @default("08:00")
  horaFechamento String @default("22:00")
  esportes       String[] @default([])
  status         ArenaStatus @default(PENDING)

  user         User          @relation(fields: [userId], references: [id])
  gameSessions GameSession[]
  quadras      Quadra[]
}

model Quadra {
  id        Int      @id @default(autoincrement())
  arenaId   Int
  nome      String
  esportes  String[]
  descricao String?
  ativa     Boolean  @default(true)
  createdAt DateTime @default(now())

  arena    Arena         @relation(fields: [arenaId], references: [id], onDelete: Cascade)
  horarios HorarioSlot[]
  reservas Reserva[]
}

model HorarioSlot {
  id         Int      @id @default(autoincrement())
  quadraId   Int
  data       String   // Formato YYYY-MM-DD
  horaInicio Int      // 0..23
  disponivel Boolean  @default(true)
  preco      Decimal?
  esporte    String?
  duracao    Int      @default(60)
  intervalo  Int      @default(10)

  quadra   Quadra    @relation(fields: [quadraId], references: [id], onDelete: Cascade)
  reservas Reserva[]

  @@unique([quadraId, data, horaInicio])
}

model Reserva {
  id              Int      @id @default(autoincrement())
  quadraId        Int
  horarioSlotId   Int
  atletaUserId    Int?
  cpfCliente      String?
  nomeCliente     String?
  telefoneCliente String?
  data            DateTime
  status          String   @default("PENDENTE") // PENDENTE | CONFIRMADA | CANCELADA
  esporte         String?
  valorPago       Decimal?
  createdAt       DateTime @default(now())

  quadra      Quadra      @relation(fields: [quadraId], references: [id])
  horarioSlot HorarioSlot @relation(fields: [horarioSlotId], references: [id])
  atletaUser  User?       @relation("ReservasAtleta", fields: [atletaUserId], references: [id])
}

model Atleta {
  id           Int     @id @default(autoincrement())
  userId       Int     @unique
  apelido      String?
  ranking      Int     @default(0)
  telefone     String?
  localizacao  String?
  esportes     String?
  nivel        String?
  notificacoes String?

  user    User   @relation(fields: [userId], references: [id])
}

model Profissional {
  id            Int     @id @default(autoincrement())
  userId        Int     @unique
  especialidade String
  valorHora     Decimal

  user          User    @relation(fields: [userId], references: [id])
}

// ─── Grupos ──────────────────────────────────────────────────────────────────

model Group {
  id           Int             @id @default(autoincrement())
  name         String
  description  String?
  city         String
  sport        String
  nivel        String?         // Nível mínimo: Iniciante, Intermediário, Avançado
  maxMembers   Int             @default(20)
  photo        String?
  visibility   GroupVisibility @default(REQUEST_ONLY)
  inviteToken  String?         @unique
  createdAt    DateTime        @default(now())

  members      GroupMember[]
  gameSessions GameSession[]
}

model GroupMember {
  id       Int               @id @default(autoincrement())
  groupId  Int
  userId   Int
  role     GroupMemberRole   @default(GUEST)
  status   GroupMemberStatus @default(PENDING)
  joinedAt DateTime          @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

// ─── Sessões de Jogo ─────────────────────────────────────────────────────────

model GameSession {
  id                  Int               @id @default(autoincrement())
  groupId             Int
  arenaId             Int?
  createdByUserId     Int
  title               String
  description         String?
  date                DateTime
  maxStarters         Int               @default(10)
  maxReserves         Int               @default(5)
  visibility          GameVisibility    @default(GROUP_ONLY)
  status              GameSessionStatus @default(DRAFT)
  cancelDeadlineHours Int               @default(24)
  autoPromoteReserves Boolean           @default(true)
  fichasPerPlayer     Int               @default(1)
  createdAt           DateTime          @default(now())

  group     Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  arena     Arena?       @relation(fields: [arenaId], references: [id])
  createdBy User         @relation("GameSessionCreator", fields: [createdByUserId], references: [id])
  players   GamePlayer[]
  ratings   GameRating[]
}

model GamePlayer {
  id            Int              @id @default(autoincrement())
  gameSessionId Int
  userId        Int
  status        GamePlayerStatus @default(RESERVE)
  confirmedAt   DateTime?
  fichaDeducted Boolean          @default(false)
  joinedAt      DateTime         @default(now())

  gameSession GameSession @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])

  @@unique([gameSessionId, userId])
}

// ─── Avaliações Pós-Jogo ─────────────────────────────────────────────────────

model GameRating {
  id            Int      @id @default(autoincrement())
  gameSessionId Int
  fromUserId    Int
  toUserId      Int
  score         Int      // 1 a 5
  comment       String?
  createdAt     DateTime @default(now())

  gameSession GameSession @relation(fields: [gameSessionId], references: [id])
  fromUser    User        @relation("RatingGiven", fields: [fromUserId], references: [id])
  toUser      User        @relation("RatingReceived", fields: [toUserId], references: [id])

  @@unique([gameSessionId, fromUserId, toUserId])
}

// ─── Carteira / Fichas ───────────────────────────────────────────────────────

model WalletTransaction {
  id          Int      @id @default(autoincrement())
  userId      Int
  amount      Int      // Positivo = crédito, Negativo = débito
  description String
  type        String   // PURCHASE | GAME_JOIN | GAME_CANCEL_REFUND | ADMIN_CREDIT
  referenceId Int?     // ID da GameSession se aplicável
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model TokenPackage {
  id        Int      @id @default(autoincrement())
  tokens    Int      // Number of tokens/fichas (e.g., 5, 10, 20)
  price     Decimal  // Price of the package
  popular   Boolean  @default(false) // Highlights "Mais Popular" package
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
